[Unit]
Description=CareerBridge Telegram Bot
After=postgresql.service network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/corvus
EnvironmentFile=/opt/corvus/.env
ExecStart=/usr/bin/python3 /opt/corvus/__vps_build/telegram_bot.py
Restart=always
RestartSec=10
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=corvus-bot

[Install]
WantedBy=multi-user.target
